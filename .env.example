# Chave da API da Anthropic (Claude).
# Gere em: https://console.anthropic.com  ->  Settings -> API Keys
#
# Recomendado: crie a chave dentro de um Workspace com spend limit,
# para que o gasto deste projeto fique isolado e limitado.
#
# Copie este arquivo para .env.local e preencha o valor real.
# O .env.local NUNCA deve ser commitado.
ANTHROPIC_API_KEY=your_api_key_here
